# Chave secreta do Django (gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=django-insecure-troque-antes-de-colocar-em-producao

# Ative apenas em desenvolvimento
DEBUG=True

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Integração LLM / OpenRouter ──────────────────────────────────────────────
# Obtenha sua chave em: https://openrouter.ai/keys
LLM_API_KEY=

# Provedor (openai, anthropic, google — mapeado pelo OpenRouter)
LLM_PROVIDER=openai

# Modelo no formato provider/model — veja https://openrouter.ai/models
LLM_MODEL=nvidia/nemotron-nano-9b-v2:free

# Timeout em segundos para cada requisição ao LLM
LLM_TIMEOUT=60

# ─── Identificação do site nos cabeçalhos OpenRouter ─────────────────────────
SITE_URL=http://localhost:8000
SITE_NAME=Ajuda Tech

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
